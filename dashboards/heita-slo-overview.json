{
  "title": "Heita CRM SLO Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "tags": [
    "heita",
    "slo",
    "red",
    "dlq",
    "ai",
    "redis",
    "webhooks",
    "queues"
  ],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP error rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(heita_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(heita_http_requests_total[5m]))"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 7
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Availability burn rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(heita_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(heita_http_requests_total[5m]))) / 0.001"
        }
      ],
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 7
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Availability budget remaining (30d)",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - ((sum(increase(heita_http_requests_total{status=~\"5..\"}[30d])) / sum(increase(heita_http_requests_total[30d]))) / 0.001)"
        }
      ],
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 7
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP P99 latency by route",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum(rate(heita_http_request_duration_seconds_bucket[5m])) by (le, route))"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 7
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Webhook ingestion error rate by provider",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (rate(heita_webhook_events_total{status=\"error\"}[5m])) / sum by (provider) (rate(heita_webhook_events_total[5m]))"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 7
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Webhook burn rate by provider",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum by (provider) (rate(heita_webhook_events_total{status=\"error\"}[5m])) / sum by (provider) (rate(heita_webhook_events_total[5m]))) / 0.001"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 8,
        "h": 7
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "OTP request and auth failure rates",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(heita_otp_requests_total[5m]) or rate(heita_auth_attempts_total{status=\"failure\"}[5m])"
        }
      ],
      "gridPos": {
        "x": 8,
        "y": 14,
        "w": 8,
        "h": 7
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Queue completion and failure rates",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue, status) (rate(heita_queue_jobs_total[10m]))"
        }
      ],
      "gridPos": {
        "x": 16,
        "y": 14,
        "w": 8,
        "h": 7
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "DLQ pending jobs",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "heita_dlq_pending_jobs"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 6,
        "h": 6
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "AI chat error rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(heita_ai_chat_requests_total{status=\"error\"}[10m])"
        }
      ],
      "gridPos": {
        "x": 6,
        "y": 21,
        "w": 6,
        "h": 6
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "AI chat burn rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(heita_ai_chat_requests_total{status=\"error\"}[30m])) / sum(rate(heita_ai_chat_requests_total[30m]))) / 0.01"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 21,
        "w": 6,
        "h": 6
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Redis errors",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROMETHEUS_DS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(heita_redis_errors_total[5m])"
        }
      ],
      "gridPos": {
        "x": 18,
        "y": 21,
        "w": 6,
        "h": 6
      }
    }
  ]
}
