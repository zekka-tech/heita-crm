{
  "name": "heita-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:setup": "bash ./docker/setup-models.sh",
    "worker:dev": "tsx watch src/workers/index.ts",
    "vapid:generate": "node -e \"const wp=require('web-push');console.log(JSON.stringify(wp.generateVAPIDKeys(),null,2))\"",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.925.0",
    "@aws-sdk/s3-request-presigner": "^3.925.0",
    "@auth/prisma-adapter": "^2.10.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bullmq": "^5.63.1",
    "csv-parse": "^6.1.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.11.0",
    "next": "^15.5.18",
    "next-auth": "beta",
    "pg": "^8.16.3",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.18",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.7"
  }
}
