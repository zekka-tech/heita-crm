{
  "name": "heita-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "HEITA_BUILD_PHASE=1 next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run tests/unit/a11y.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:setup": "bash ./docker/setup-models.sh",
    "worker:dev": "tsx watch src/workers/index.ts",
    "vapid:generate": "node -e \"const wp=require('web-push');console.log(JSON.stringify(wp.generateVAPIDKeys(),null,2))\"",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@aws-sdk/client-s3": "^3.925.0",
    "@aws-sdk/client-textract": "^3.1055.0",
    "@aws-sdk/s3-request-presigner": "^3.925.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@sentry/nextjs": "^10.53.1",
    "@tanstack/react-query": "^5.100.14",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "bullmq": "^5.63.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.11.0",
    "next": "^15.5.18",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^3.26.5",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.3.0",
    "web-push": "^3.6.7",
    "sonner": "^2.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.18",
    "jsdom": "^26.1.0",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0"
  }
}
