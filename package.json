{
  "name": "heita-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate && node scripts/copy-tesseract-assets.mjs",
    "copy-tesseract-assets": "node scripts/copy-tesseract-assets.mjs",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/copy-tesseract-assets.mjs",
    "build": "HEITA_BUILD_PHASE=1 next build && npm run build:worker",
    "build:worker": "esbuild src/workers/index.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=dist/worker.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run tests/unit/a11y.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:app-role": "APP_DATABASE_URL=\"${APP_DATABASE_URL:-postgresql://heita_app:heita_app@localhost:5432/heita}\" playwright test --project=smoke",
    "test:load": "tsx tests/load/run.ts",
    "test:rls": "tsx scripts/rls-live.ts",
    "db:migrate": "prisma migrate dev",
    "db:setup": "tsx scripts/db-preflight.ts && prisma migrate deploy && prisma db seed",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:staging": "tsx prisma/seed-staging.ts",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:setup": "bash ./docker/setup-models.sh",
    "worker:dev": "tsx watch src/workers/index.ts",
    "vapid:generate": "node -e \"const wp=require('web-push');console.log(JSON.stringify(wp.generateVAPIDKeys(),null,2))\"",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "bundle-check": "node scripts/check-bundle-size.mjs",
    "lighthouse": "lhci autorun",
    "test:eval": "vitest run --config vitest.eval.config.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/s3-request-presigner": "^3.1069.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@sentry/nextjs": "^10.58.0",
    "@tanstack/react-query": "^5.100.14",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "bullmq": "^5.78.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "ioredis": "^5.11.0",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.11.0",
    "next": "^15.5.19",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.13.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "posthog-js": "^1.386.8",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "sonner": "^2.0.5",
    "stripe": "^22.2.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.3.0",
    "tesseract.js": "^7.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^22.19.21",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.4",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autocannon": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.19",
    "jsdom": "^26.1.0",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "@hono/node-server": ">=1.19.13",
    "dompurify": ">=3.4.11"
  }
}
