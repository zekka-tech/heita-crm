# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://heita:heita_dev@localhost:5432/heita_dev"
REDIS_URL="redis://localhost:6379"
# Per-pod connection limit. Set to floor(max_connections / num_pods).
# With PgBouncer in transaction mode, set to 5 and let PgBouncer manage the pool.
# Without PgBouncer on a shared 100-connection Postgres: 20 with up to 4 pods.
DB_CONNECTION_LIMIT="20"
DEPLOYMENT_READ_ONLY="0"
# Failures before the circuit breaker opens for an external service
CIRCUIT_BREAKER_FAILURE_THRESHOLD="5"
# How long (ms) the circuit stays open before attempting half-open retry
CIRCUIT_BREAKER_COOLDOWN_MS="60000"

# ─── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""
AUTH_APPLE_TEAM_ID=""
AUTH_APPLE_KEY_ID=""
# HMAC secret signing staff invite tokens (staff/accept flow).
# Generate with: openssl rand -base64 32
STAFF_INVITE_SECRET=""
# How long (seconds) a staff step-up MFA verification stays valid. Default 900.
STAFF_STEP_UP_WINDOW_SECONDS="900"
# Comma-separated user IDs allowed to access platform-admin surfaces such as the
# CAC/LTV cohort dashboard (/admin/cac-ltv). Empty = no one has access (fail-closed).
PLATFORM_ADMIN_USER_IDS=""
# Rand account credit a referrer earns when a business it referred pays its first
# invoice (B2B merchant referral loop). Default 500.
MERCHANT_REFERRAL_REWARD_ZAR="500"

# ─── WhatsApp Cloud API (Meta) ────────────────────────────────────────────────
WHATSAPP_APP_ID=""
WHATSAPP_APP_SECRET=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_ACCESS_TOKEN=""
# Sender phone-number id and WhatsApp Business Account id (Meta → WhatsApp → API Setup).
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
# Public-facing WhatsApp number shown in the UI (E.164, e.g. +27711234567).
NEXT_PUBLIC_WHATSAPP_NUMBER=""
WHATSAPP_API_VERSION="v21.0"
# Pre-approved Meta template for event reminders. Body params:
# {{1}} business name, {{2}} event title, {{3}} when label.
WHATSAPP_EVENT_REMINDER_TEMPLATE="heita_event_reminder"
WHATSAPP_EVENT_REMINDER_TEMPLATE_LANG="en_ZA"
# Pre-approved Meta marketing template for promotion broadcasts. Body params:
# {{1}} business name, {{2}} promotion title, {{3}} details.
WHATSAPP_PROMOTION_TEMPLATE="heita_promotion"
WHATSAPP_PROMOTION_TEMPLATE_LANG="en_ZA"

# ─── Africa's Talking (SMS, voice) ────────────────────────────────────────────
AT_API_KEY=""
AT_USERNAME="sandbox"
AT_SENDER_ID="HEITA"
AT_WEBHOOK_SECRET=""
# Optional comma-separated extra IPs allowed to call the AT delivery webhook,
# in addition to the documented Africa's Talking ranges.
AT_ALLOWLIST_IPS=""

# ─── AI Runtimes ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="llama3.2"
OLLAMA_EMBED_MODEL="mxbai-embed-large"
# Optional cross-encoder reranker for RAG. Leave empty to use pure-vector
# retrieval; falls back gracefully if the model isn't pulled.
OLLAMA_RERANK_MODEL=""

# Encryption secret for bring-your-own-model (BYOM) provider API keys stored
# in Postgres (AES-256-GCM). Falls back to AUTH_SECRET when empty — set a
# dedicated value in production so auth and credential encryption can rotate
# independently.
AI_CREDENTIALS_SECRET=""

# Receipt OCR fallback. Primary OCR runs client-side (Tesseract.js, in-browser);
# DeepSeek's vision API is only called server-side when on-device text is
# missing or insufficient. Optional — leave empty to disable the cloud fallback.
DEEPSEEK_API_KEY=""

# Web-source crawler User-Agent (AI workspace "Add web pages"). Optional.
# The crawler is SSRF-guarded, same-origin, robots.txt-respecting, and capped.
# Re-crawls of sources with a refresh interval are driven by the
# /api/cron/refresh-web-sources endpoint (scheduled externally with CRON_SECRET).
CRAWLER_USER_AGENT="HeitaBot/1.0 (+https://heita.co.za/bot)"

# ─── Object Storage (Cloudflare R2 / MinIO) ───────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="heita-files"
R2_PUBLIC_URL=""
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="heita-files"
MALWARE_SCAN_MODE="disabled"        # disabled | clamav
MALWARE_SCAN_REQUIRED="0"
CLAMAV_HOST="127.0.0.1"
CLAMAV_PORT="3310"
CLAMAV_TIMEOUT_MS="15000"

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@heita.co.za"

# ─── Realtime (Pusher) ────────────────────────────────────────────────────────
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"
PUSHER_APP_ID=""
PUSHER_SECRET=""

# ─── Email (Resend) ───────────────────────────────────────────────────────────
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@heita.co.za"

# ─── App config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Heita"
NEXT_PUBLIC_APP_VERSION="0.1.0"
CRON_SECRET=""
LOG_LEVEL="info"
POS_SHARED_SECRET=""
POS_RATE_LIMIT_PER_BUSINESS_PER_MINUTE="180"
POS_RATE_LIMIT_PER_BUSINESS_IP_PER_MINUTE="60"
METRICS_BEARER_TOKEN=""          # Generate with: openssl rand -base64 32
# Set to "1" in non-production environments to expose OTP codes in the API response for e2e tests.
E2E_EXPOSE_DEV_OTP="0"
# Set to "true" in development/staging to enable the one-click dev-bypass sign-in (never in prod).
ENABLE_DEV_AUTH_BYPASS="false"

# ─── Sentry (Error Tracking & Performance) ────────────────────────────────────
# Create a project at https://sentry.io → Settings → Projects → Client Keys → DSN
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE="0"
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE="0.5"
SENTRY_AUTH_TOKEN=""             # For source-map uploads in CI (sentry-cli)
SENTRY_ORG=""                    # Sentry org slug (source-map upload)
SENTRY_PROJECT=""                # Sentry project slug (source-map upload)

# ─── OpenTelemetry (Distributed Tracing) ──────────────────────────────────────
# Leave empty to use Sentry as the OTEL backend (recommended — no extra infra).
# Set OTLP_ENDPOINT to forward all spans to a dedicated OTLP/HTTP collector
# (Jaeger/Tempo/Grafana). This is the variable the bundled instrumentation reads.
OTLP_ENDPOINT=""
# Standard OTel SDK variables (consumed by the SDK directly, if used).
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_EXPORTER_OTLP_HEADERS=""
OTEL_SERVICE_NAME="heita-crm"

# ─── External API Timeouts ────────────────────────────────────────────────────
# Default timeout for outbound API calls. Tune per provider as needed.
EXTERNAL_API_TIMEOUT_MS="10000"

# ─── Webhook Verification Secrets ──────────────────────────────────────────────
# Shared secret for Resend/Svix email webhook signature verification.
# If unset, the /api/email/webhook endpoint skips signature checks (dev only).
EMAIL_WEBHOOK_SECRET=""
# Shared secret protecting the /api/analytics/export endpoint.
# Generate with: openssl rand -base64 32
BASKET_REPORT_SECRET=""

# ─── Billing (Yoco, Stripe, PayFast) ───────────────────────────────────────────
# Each provider is optional. For any enabled provider, set both checkout/API
# credentials and webhook verification secrets before production traffic.
YOCO_SECRET_KEY=""
YOCO_WEBHOOK_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PAYFAST_MERCHANT_ID=""
PAYFAST_MERCHANT_KEY=""
PAYFAST_PASSPHRASE=""
PAYFAST_MODE="sandbox"

# ─── Bot protection (Cloudflare Turnstile) ────────────────────────────────────
# Required in production — enforces bot protection on OTP endpoints.
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# ─── Product analytics (PostHog) ──────────────────────────────────────────────
# Optional, consent-gated and PII-scrubbed. Self-host in-region for POPIA.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# ─── Runtime / ops ────────────────────────────────────────────────────────────
# Comma-separated trusted proxy IPs used when extracting the real client IP
# (rate limiting, webhook allowlists). Set to your load balancer / CDN egress IPs.
TRUSTED_PROXY_IPS=""
# Max time (ms) to drain in-flight work on SIGTERM before forced exit. Default 10000.
SHUTDOWN_TIMEOUT_MS="10000"
# CDN hostname used for dns-prefetch/preconnect (e.g. "pub-abc.r2.dev" or "cdn.heita.co.za").
NEXT_PUBLIC_R2_HOST=""

# ─── Queue dev flags ──────────────────────────────────────────────────────────
# Set to "1" to run jobs inline (synchronously) instead of via BullMQ — useful
# for local dev / tests when no Redis worker is running. Leave "0" in production.
AI_INGEST_INLINE="0"
CUSTOMER_IMPORT_INLINE="0"
