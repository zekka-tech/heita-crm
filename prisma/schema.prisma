generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String              @id @default(cuid())
  name              String?
  email             String?             @unique
  emailVerified     DateTime?
  image             String?
  phone             String?             @unique
  phoneVerifiedAt   DateTime?
  preferredAiMode   String?             @default("auto")
  pendingEmail      String?
  notificationPreferences Json?
  sessionVersion    Int                 @default(0)
  deletedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  accounts          Account[]
  sessions          Session[]
  memberships       Membership[]
  staffMemberships  StaffMember[]
  staffInvitesSent  StaffInvite[]       @relation("StaffInviteIssuer")
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  otpCodes          OtpCode[]
  aiChatSessions    AiChatSession[]
  loyaltyEvents     LoyaltyTransaction[]
  messages          Message[]
  consents              UserConsent[]
  promotionRedemptions  PromotionRedemption[]
  aiTokenUsages         AiTokenUsage[]
  staffAuditLogs        StaffAuditLog[]      @relation("StaffAuditActor")
  referralCodesOwned ReferralCode[]
  importRuns        CustomerImportRun[]  @relation("CustomerImportActor")
  ocrReceipts       OcrReceipt[]
  reviewedReceipts  OcrReceipt[]         @relation("OcrReceiptReviewer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpCode {
  id           String         @id @default(cuid())
  userId       String?
  phone        String
  codeHash     String
  purpose      OtpPurpose
  channel      MessageChannel
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int            @default(0)
  createdAt    DateTime       @default(now())
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone, purpose])
  @@index([expiresAt])
}

model Business {
  id                    String               @id @default(cuid())
  planId                BusinessPlanId       @default(FREE)
  slug                  String               @unique
  name                  String
  legalName             String?
  description           String?
  category              BusinessCategory
  province              Province
  phone                 String?
  email                 String?
  logoUrl               String?
  coverImageUrl         String?
  loyaltySignupBonus    Int                  @default(0)
  pointsExpiryDays      Int                  @default(365)
  wabaPhoneId           String?              @unique
  whatsappPhoneNumber   String?
  addressLine1          String?
  addressLine2          String?
  suburb                String?
  city                  String?
  postalCode            String?
  isActive              Boolean              @default(true)
  deletedAt             DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  qrCodes               QrCode[]
  joinLinks             JoinLink[]
  memberships           Membership[]
  staffMembers          StaffMember[]
  aiWorkspace           AiWorkspace?
  documents             BusinessDocument[]
  documentChunks        DocumentChunk[]
  aiChatSessions        AiChatSession[]
  loyaltyTiers          LoyaltyTier[]
  rewards               Reward[]
  promotions            Promotion[]
  events                Event[]
  messages              Message[]
  loyaltyTransactions   LoyaltyTransaction[]
  consents              UserConsent[]
  promotionRedemptions  PromotionRedemption[]
  staffInvites          StaffInvite[]
  aiTokenUsages         AiTokenUsage[]
  staffAuditLogs        StaffAuditLog[]
  referralCodes         ReferralCode[]
  importRuns            CustomerImportRun[]
  subscriptions         BusinessSubscription[]
  invoices              BusinessInvoice[]
  ocrReceipts           OcrReceipt[]
}

model QrCode {
  id          String    @id @default(cuid())
  businessId  String
  name        String
  token       String    @unique
  description String?
  scanCount   Int       @default(0)
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model JoinLink {
  id          String      @id @default(cuid())
  businessId  String
  token       String      @unique
  name        String
  channel     JoinChannel
  clickCount  Int         @default(0)
  isActive    Boolean     @default(true)
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, channel])
}

model Membership {
  id             String               @id @default(cuid())
  businessId     String
  userId         String
  joinChannel    JoinChannel
  joinedAt       DateTime             @default(now())
  pointsBalance  Int                  @default(0)
  tierId         String?
  referredByCodeId String?
  referralRewardedAt DateTime?
  isActive       Boolean              @default(true)
  business       Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier           LoyaltyTier?         @relation(fields: [tierId], references: [id], onDelete: SetNull)
  transactions   LoyaltyTransaction[]
  referredByCode ReferralCode?        @relation("ReferralAttribution", fields: [referredByCodeId], references: [id], onDelete: SetNull)

  @@unique([businessId, userId])
  @@index([userId])
  @@index([referredByCodeId])
}

model StaffMember {
  id          String    @id @default(cuid())
  businessId  String
  userId      String
  role        StaffRole
  invitedById String?
  joinedAt    DateTime  @default(now())
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId, role])
}

model StaffInvite {
  id           String            @id @default(cuid())
  businessId   String
  email        String?
  phone        String?
  role         StaffRole
  tokenHash    String            @unique
  invitedById  String
  status       StaffInviteStatus @default(PENDING)
  expiresAt    DateTime
  acceptedAt   DateTime?
  acceptedById String?
  revokedAt    DateTime?
  createdAt    DateTime          @default(now())
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invitedBy    User              @relation("StaffInviteIssuer", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([businessId, status])
  @@index([email])
  @@index([phone])
}

enum StaffInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model AiWorkspace {
  id               String            @id @default(cuid())
  businessId       String            @unique
  systemPrompt     String?
  preferredRuntime String            @default("auto")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  documents        BusinessDocument[]
  chatSessions     AiChatSession[]
}

model BusinessDocument {
  id             String          @id @default(cuid())
  workspaceId    String
  businessId     String
  title          String
  fileName       String
  mimeType       String
  storageKey     String          @unique
  sizeBytes      Int
  status         DocumentStatus  @default(PENDING)
  sourceUrl      String?
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspace      AiWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  chunks         DocumentChunk[]

  @@index([workspaceId, status])
  @@index([businessId, createdAt])
}

model DocumentChunk {
  id           String                     @id @default(cuid())
  documentId   String
  businessId   String
  chunkIndex   Int
  content      String
  metadata     Json?
  embedding    Unsupported("vector(1024)")?
  createdAt    DateTime                   @default(now())
  document     BusinessDocument           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  business     Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([businessId])
}

model AiChatSession {
  id           String          @id @default(cuid())
  workspaceId  String
  businessId   String
  userId       String?
  title        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  workspace    AiWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  business     Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages     AiChatMessage[]
  tokenUsage   AiTokenUsage[]

  @@index([businessId, createdAt])
}

model AiChatMessage {
  id         String        @id @default(cuid())
  sessionId  String
  role       String
  content    String
  model      String?
  latencyMs  Int?
  promptTokens Int?
  completionTokens Int?
  metadata   Json?
  createdAt  DateTime      @default(now())
  session    AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model LoyaltyTier {
  id            String        @id @default(cuid())
  businessId    String
  name          String
  minPoints     Int
  perks         Json?
  rank          Int
  colorHex      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  memberships   Membership[]

  @@unique([businessId, name])
  @@unique([businessId, rank])
}

model Reward {
  id            String      @id @default(cuid())
  businessId    String
  title         String
  description   String?
  pointsCost    Int
  stock         Int?
  imageUrl      String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, isActive])
}

model Promotion {
  id              String                 @id @default(cuid())
  businessId      String
  title           String
  description     String?
  type            PromotionType
  startsAt        DateTime
  endsAt          DateTime
  imageUrl        String?
  code            String?
  targetTierIds   String[]               @default([])
  broadcastAt     DateTime?
  broadcastSentBy String?
  isActive        Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  business        Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  redemptions     PromotionRedemption[]

  @@unique([businessId, code], name: "Promotion_businessId_code_key")
  @@index([businessId, startsAt, endsAt])
  @@index([businessId, isActive, endsAt])
}

model PromotionRedemption {
  id          String    @id @default(cuid())
  promotionId String
  userId      String
  businessId  String
  redeemedAt  DateTime  @default(now())
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([promotionId, userId])
  @@index([businessId, redeemedAt])
}

model Event {
  id              String      @id @default(cuid())
  businessId      String
  title           String
  description     String?
  startsAt        DateTime
  endsAt          DateTime?
  location        String?
  isReminderOn    Boolean     @default(true)
  reminderSentAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, startsAt])
  @@index([startsAt, isReminderOn, reminderSentAt])
}

model Message {
  id             String          @id @default(cuid())
  businessId     String
  userId         String?
  contactPhone   String?
  channel        MessageChannel
  direction      String
  externalId     String?
  status         MessageStatus?
  body           String
  metadata       Json?
  sentAt         DateTime?
  readByStaffAt  DateTime?
  createdAt      DateTime        @default(now())
  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  attachments    MessageAttachment[]

  @@index([businessId, channel, createdAt])
  @@index([businessId, contactPhone, createdAt])
  @@index([businessId, readByStaffAt])
  @@index([userId])
  @@unique([channel, externalId])
}

model LoyaltyTransaction {
  id             String            @id @default(cuid())
  businessId     String
  membershipId   String
  userId         String?
  type           TransactionType
  pointsDelta    Int
  description    String?
  expiresAt      DateTime?
  refundSourceId String?           @unique
  expirySourceId String?           @unique
  metadata       Json?
  createdAt      DateTime          @default(now())
  business       Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  membership     Membership        @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  refundSource   LoyaltyTransaction? @relation("RefundSource", fields: [refundSourceId], references: [id], onDelete: SetNull)
  refundTarget   LoyaltyTransaction? @relation("RefundSource")
  expirySource   LoyaltyTransaction? @relation("ExpirySource", fields: [expirySourceId], references: [id], onDelete: SetNull)
  expiryTarget   LoyaltyTransaction? @relation("ExpirySource")

  @@index([businessId, createdAt])
  @@index([membershipId, createdAt])
  @@index([expiresAt])
}

model MessageAttachment {
  id              String   @id @default(cuid())
  messageId       String
  mediaType       String
  mimeType        String?
  fileName        String?
  byteSize        Int?
  externalMediaId String?
  storageKey      String?
  sourceUrl       String?
  createdAt       DateTime @default(now())
  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@index([externalMediaId])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  title       String
  body        String
  type        String
  isRead      Boolean   @default(false)
  actionUrl   String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  readAt      DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model ReferralCode {
  id          String       @id @default(cuid())
  businessId  String
  ownerUserId String
  code        String       @unique
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  ownerUser   User         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  referrals   Membership[] @relation("ReferralAttribution")

  @@unique([businessId, ownerUserId])
  @@index([businessId, isActive])
}

model CustomerImportRun {
  id           String       @id @default(cuid())
  businessId   String
  actorUserId  String
  fileName     String
  sourceCsv    String?
  status       ImportStatus @default(PENDING)
  totalRows    Int          @default(0)
  importedRows Int          @default(0)
  skippedRows  Int          @default(0)
  failedRows   Int          @default(0)
  errorSummary Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  finishedAt   DateTime?
  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actorUser    User         @relation("CustomerImportActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([status, createdAt])
}

model PushSubscription {
  id          String    @id @default(cuid())
  userId      String
  endpoint    String    @unique
  p256dh      String
  auth        String
  userAgent   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserConsent {
  id         String       @id @default(cuid())
  userId     String
  businessId String?
  type       ConsentType
  channel    ConsentChannel
  source     String
  grantedAt  DateTime     @default(now())
  revokedAt  DateTime?
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business?    @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId, type, grantedAt])
  @@index([businessId, type])
}

model AiTokenUsage {
  id               String         @id @default(cuid())
  businessId       String
  sessionId        String?
  userId           String?
  runtime          String
  model            String?
  messageUnits     Int            @default(1)
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  createdAt        DateTime       @default(now())
  business         Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  session          AiChatSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([sessionId, createdAt])
}

model StaffAuditLog {
  id          String   @id @default(cuid())
  businessId  String
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actorUser   User?     @relation("StaffAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetType, targetId])
}

enum StaffRole {
  OWNER
  MANAGER
  STAFF
  AI_TRAINER
}

enum JoinChannel {
  QR_CODE
  WHATSAPP_BOT
  DIRECT_LINK
  STAFF_INVITE
  CSV_IMPORT
  GOOGLE_SIGNIN
  APPLE_SIGNIN
}

enum MessageChannel {
  SMS
  WHATSAPP
  PUSH
  EMAIL
  IN_APP
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

enum OtpPurpose {
  SIGN_IN
  SIGN_UP
  PASSWORD_RESET
  VERIFY_PHONE
  STAFF_STEP_UP
}

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  COOKIE_PREFERENCES
  WHATSAPP_MARKETING
}

enum ConsentChannel {
  WEB
  WHATSAPP
  SMS
  EMAIL
}

enum TransactionType {
  SIGNUP_BONUS
  REFERRAL_BONUS
  EARN
  REDEEM
  ADJUSTMENT
  EXPIRY
  REFUND
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum PromotionType {
  FLASH_SALE
  DISCOUNT
  BONUS_POINTS
  EVENT
}

enum Province {
  EASTERN_CAPE
  FREE_STATE
  GAUTENG
  KWAZULU_NATAL
  LIMPOPO
  MPUMALANGA
  NORTH_WEST
  NORTHERN_CAPE
  WESTERN_CAPE
}

enum BusinessCategory {
  GROCERY
  RESTAURANT
  FASHION
  BEAUTY
  HARDWARE
  PHARMACY
  SERVICES
  ENTERTAINMENT
  OTHER
}

model OcrReceipt {
  id              String              @id @default(cuid())
  businessId      String
  userId          String
  membershipId    String?
  imageUrl        String
  rawOcrText      String?
  parsedTotal     Decimal?          @db.Decimal(10, 2)
  parsedBusiness  String?
  pointsToAward   Int?
  status          OcrReceiptStatus    @default(PENDING_REVIEW)
  reviewedAt      DateTime?
  reviewedBy      String?
  transactionId   String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  business        Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer        User?               @relation("OcrReceiptReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([businessId, status, createdAt])
  @@index([userId])
}

enum OcrReceiptStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  PROCESSED
}

model BusinessSubscription {
  id                String                   @id @default(cuid())
  businessId        String
  planId            BusinessPlanId
  status            SubscriptionStatus       @default(ACTIVE)
  yocoCustomerId    String?
  yocoSubscriptionId String?                 @unique
  currentPeriodStart DateTime
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean                  @default(false)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  business          Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
}

model BusinessInvoice {
  id             String          @id @default(cuid())
  businessId     String
  planId         BusinessPlanId
  amountZar      Int
  status         InvoiceStatus   @default(PENDING)
  yocoPaymentId  String?         @unique
  issuedAt       DateTime        @default(now())
  paidAt         DateTime?
  periodStart    DateTime
  periodEnd      DateTime
  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum InvoiceStatus {
  PENDING
  PAID
  VOID
}

enum BusinessPlanId {
  FREE
  GROWTH
  SCALE
}
