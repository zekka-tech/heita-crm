# ─── Heita CRM — production env for the Docker Compose (VPS) deploy ───────────
#
# Copy to `.env.production` on the VPS and fill in. This file is consumed by:
#   • app      — all application secrets
#   • postgres — POSTGRES_* below
#   • redis    — REDIS_PASSWORD below
#   • migrate  — DATABASE_URL
#   • caddy    — DOMAIN, ACME_EMAIL
#
# Start from .env.example for the full list of application variables; the keys
# below are the ones whose VALUES differ inside the Docker network or are
# required by the compose file specifically.

# ─── Postgres (consumed by the postgres service + interpolated by compose) ────
POSTGRES_USER="heita"
POSTGRES_PASSWORD="CHANGE_ME_strong_password"
POSTGRES_DB="heita"
# heita_app is the unprivileged app role (NOBYPASSRLS). docker/postgres/init.sql
# creates it with this password on first boot. Must match DATABASE_URL below.
POSTGRES_APP_PASSWORD="CHANGE_ME_app_password"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD="CHANGE_ME_strong_password"

# ─── Service-to-service URLs (use Docker service names, NOT localhost) ────────
# DATABASE_URL  → heita_app (app runtime, NOBYPASSRLS — RLS is enforced).
# MIGRATION_DATABASE_URL → heita owner (migrate service only, for DDL).
DATABASE_URL="postgresql://heita_app:CHANGE_ME_app_password@postgres:5432/heita"
MIGRATION_DATABASE_URL="postgresql://heita:CHANGE_ME_strong_password@postgres:5432/heita"
REDIS_URL="redis://:CHANGE_ME_strong_password@redis:6379"

# ─── Malware scanning (ClamAV sidecar — clamd TCP on heita_internal) ─────────
# MALWARE_SCAN_MODE: "clamav" in production; "disabled" will fail env validation.
# MALWARE_SCAN_REQUIRED: "1" makes uploads fail-closed if clamd is unreachable.
# CLAMAV_HOST / CLAMAV_PORT: Docker service name resolves over heita_internal.
# CLAMAV_TIMEOUT_MS: How long to wait for a scan response (default 15 000 ms).
MALWARE_SCAN_MODE="clamav"
MALWARE_SCAN_REQUIRED="1"
CLAMAV_HOST="clamav"
CLAMAV_PORT="3310"
CLAMAV_TIMEOUT_MS="15000"

# ─── Reverse proxy / TLS (consumed by the caddy service + Caddyfile) ──────────
DOMAIN="app.heita.co.za"
ACME_EMAIL="ops@heita.co.za"

# ─── Public URLs ──────────────────────────────────────────────────────────────
AUTH_URL="https://app.heita.co.za"
NEXT_PUBLIC_APP_URL="https://app.heita.co.za"

# ─── Everything else ──────────────────────────────────────────────────────────
# Copy the remaining keys from .env.example (AUTH_SECRET, WhatsApp, Africa's
# Talking, ANTHROPIC_API_KEY, R2_*, VAPID, Pusher, email, CRON_SECRET,
# METRICS_BEARER_TOKEN, Sentry, …) and set real production values.
# Generate secrets with: openssl rand -base64 32
